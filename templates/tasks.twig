{% extends "layout.twig" %}
{% block header_title %}Twoje Zadania{% endblock %}
{% block content %}
<div class="mb-6">
    <h2 class="text-[34px] font-black text-app-black tracking-tighter leading-none mt-2">Działaj!</h2>
    <p class="text-gray-500 font-medium text-[15px] mt-2">Uporządkuj plany i kategorie.</p>
</div>

<form hx-post="/grocy/tasks/group" hx-target="#task-groups" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="relative flex items-center bg-white rounded-full shadow-sm border border-gray-100/50 p-1.5 pl-5 focus-within:ring-2 focus-within:ring-app-black transition-all">
        <input type="text" name="name" placeholder="Nowa grupa (np. Praca)..." required class="flex-1 bg-transparent border-none outline-none font-bold text-app-black placeholder-gray-400 py-3 text-[15px]">
        <button type="submit" class="bg-app-black text-white w-12 h-12 rounded-full flex items-center justify-center shrink-0 hover:-translate-y-0.5 active:scale-95 transition-transform shadow-[0_4px_14px_rgba(0,0,0,0.15)]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
        </button>
    </div>
</form>

<div id="task-groups">
    {% include "partials/tasks_content.twig" %}
</div>
{% endblock %}
