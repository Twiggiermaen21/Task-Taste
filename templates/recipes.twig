{% extends "layout.twig" %}
{% block main_title %}{{ __('your_recipes') }}{% endblock %}
{% block main_subtitle %}{{ __('recipes_desc') }}{% endblock %}
{% block content %}


<form hx-post="/grocy/recipes" hx-encoding="multipart/form-data" hx-target="#recipes-list" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-6 shadow-sm border border-gray-100/50 dark:border-white/5 mb-4">
        <input type="text" name="title" placeholder="{{ __('recipe_title_placeholder') }}" required class="w-full bg-transparent border-none outline-none font-bold text-app-black dark:text-white placeholder-gray-400 py-2 px-2 text-[16px]">
        
        <div class="h-px bg-gray-100 dark:bg-white/5 my-2"></div>
        
        <textarea name="instructions" placeholder="{{ __('instructions_placeholder') }}" class="w-full bg-transparent border-none outline-none font-medium text-gray-500 dark:text-gray-400 placeholder-gray-400 py-2 px-2 text-[14px] resize-none h-14"></textarea>
        
        <div class="h-px bg-gray-100 dark:bg-white/5 my-2"></div>
        
        <div class="flex items-center gap-4 px-2 mt-2">
            <select name="category" class="bg-gray-50 dark:bg-gray-800 rounded-xl px-3 py-2 text-sm font-bold text-app-black dark:text-white border-none outline-none cursor-pointer">
                <option value="Śniadanie">🍳 Śniadanie</option>
                <option value="Obiad">🍝 Obiad</option>
                <option value="Kolacja">🥗 Kolacja</option>
                <option value="Deser">🍰 Deser</option>
                <option value="Inne">🍴 Inne</option>
            </select>
            
            <label class="flex items-center gap-2 cursor-pointer bg-gray-50 dark:bg-gray-800 rounded-xl px-3 py-2 text-sm font-bold text-gray-500 dark:text-gray-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span>Zdjęcie</span>
                <input type="file" name="image" class="hidden" accept="image/*">
            </label>
        </div>
    </div>
    <button type="submit" class="main-btn relative z-20">
        {{ __('save_to_db') }} <span class="tracking-tighter font-black text-app-yellow">>></span>
    </button>
</form>

<div id="recipes-list">
    {% include "partials/recipes_content.twig" %}
</div>

<!-- Recipe Detail Modal -->
<div id="recipe-modal" class="fixed inset-0 z-[100] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-app-black/60 backdrop-blur-sm" onclick="closeRecipeModal()"></div>
    
    <!-- Modal Content -->
    <div class="absolute bottom-0 left-0 right-0 max-w-md mx-auto h-[85vh] bg-white dark:bg-[#1A1D1F] rounded-t-[40px] shadow-2xl p-6 overflow-y-auto hide-scrollbar translate-y-full transition-transform duration-300 ease-out" id="recipe-modal-container">
        <div class="flex justify-center mb-4">
            <div class="w-12 h-1.5 bg-gray-200 dark:bg-white/10 rounded-full"></div>
        </div>
        
        <div class="absolute top-6 right-6 z-30">
            <button onclick="closeRecipeModal()" class="w-10 h-10 bg-white/20 dark:bg-white/10 backdrop-blur-md rounded-full flex items-center justify-center text-app-black dark:text-white border border-white/20 shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div id="recipe-modal-body">
            <!-- Content loaded via HTMX -->
            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-app-black dark:border-white mb-4"></div>
                <span>Ładowanie pyszności...</span>
            </div>
        </div>
    </div>
</div>

<script>
function openRecipeModal() {
    const modal = document.getElementById('recipe-modal');
    const container = document.getElementById('recipe-modal-container');
    modal.classList.remove('hidden');
    setTimeout(() => {
        container.classList.remove('translate-y-full');
    }, 10);
}

function closeRecipeModal() {
    const modal = document.getElementById('recipe-modal');
    const container = document.getElementById('recipe-modal-container');
    container.classList.add('translate-y-full');
    setTimeout(() => {
        modal.classList.add('hidden');
        document.getElementById('recipe-modal-body').innerHTML = `
            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-app-black dark:border-white mb-4"></div>
                <span>Ładowanie pyszności...</span>
            </div>
        `;
    }, 300);
}

document.body.addEventListener('htmx:afterOnLoad', function(evt) {
    if (evt.detail.target.id === 'recipe-modal-body') {
        openRecipeModal();
    }
});
</script>
{% endblock %}
