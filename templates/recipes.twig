{% extends "layout.twig" %}
{% block header_title %}Książka kucharska{% endblock %}
{% block content %}
<div class="mb-6">
    <h2 class="text-[34px] font-black text-app-black tracking-tighter leading-none mt-2">Twoje przepisy</h2>
    <p class="text-gray-500 font-medium text-[15px] mt-2">Smaczne pomysły na wyciągnięcie ręki.</p>
</div>

<form hx-post="/grocy/recipes" hx-encoding="multipart/form-data" hx-target="#recipes-list" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="bg-white rounded-[32px] p-4 shadow-sm border border-gray-100/50 mb-3 overflow-hidden group focus-within:ring-2 focus-within:ring-app-black transition-all">
        <input type="text" name="title" placeholder="Tytuł dania np. Spaghetti..." required class="w-full bg-transparent border-none outline-none font-bold text-app-black placeholder-gray-400 py-2 px-2 text-[16px]">
        
        <div class="h-px bg-gray-100 my-2"></div>
        
        <textarea name="instructions" placeholder="Krótki opis lub instrukcja (opcjonalnie)..." class="w-full bg-transparent border-none outline-none font-medium text-gray-500 placeholder-gray-400 py-2 px-2 text-[14px] resize-none h-20"></textarea>
        
        <div class="h-px bg-gray-100 my-2"></div>
        
        <div class="px-2 pt-2 pb-1">
            <input type="file" name="image" accept="image/*" class="text-[11px] text-gray-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-[11px] file:font-bold file:bg-gray-50 file:text-app-black hover:file:bg-gray-100 transition-colors w-full cursor-pointer outline-none">
        </div>
    </div>
    <button type="submit" class="w-full bg-app-black text-white py-4 rounded-full font-bold uppercase tracking-widest text-[13px] flex items-center justify-center gap-2 hover:-translate-y-1 active:scale-95 transition-transform shadow-[0_8px_20px_rgba(0,0,0,0.15)] relative z-20">
        ZAPISZ DO BAZY <span class="tracking-tighter font-black text-app-yellow">>></span>
    </button>
</form>

<div id="recipes-list">
    {% include "partials/recipes_content.twig" %}
</div>
{% endblock %}
