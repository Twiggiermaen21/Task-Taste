{% extends "layout.twig" %}
{% block header_title %}Sklepy{% endblock %}
{% block content %}
<div class="mb-6">
    <h2 class="text-[34px] font-black text-app-black tracking-tighter leading-none mt-2">Twój rynek</h2>
    <p class="text-gray-500 font-medium text-[15px] mt-2">Zarządzaj swoimi listami zakupowymi.</p>
</div>

<form hx-post="/grocy/shopping/store" hx-encoding="multipart/form-data" hx-target="#stores-list" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="relative flex flex-col bg-white rounded-[32px] shadow-sm border border-gray-100/50 p-2 pr-2 focus-within:ring-2 focus-within:ring-app-black transition-all overflow-hidden group">
        <div class="flex items-center w-full relative z-10">
            <input type="text" name="name" placeholder="Nowy sklep np. Lidl..." required class="flex-1 bg-transparent border-none outline-none font-bold text-app-black placeholder-gray-400 py-3 px-4 text-[15px]">
            <button type="submit" class="bg-app-black text-white w-12 h-12 rounded-full flex items-center justify-center shrink-0 hover:-translate-y-0.5 active:scale-95 transition-transform shadow-[0_4px_14px_rgba(0,0,0,0.15)] relative z-20">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
            </button>
        </div>
        <div class="px-4 pb-2 relative z-10">
            <input type="file" name="image" accept="image/*" class="text-[11px] text-gray-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-[11px] file:font-bold file:bg-gray-50 file:text-app-black hover:file:bg-gray-100 transition-colors w-full cursor-pointer outline-none">
        </div>
    </div>
</form>

<div id="stores-list">
    {% include "partials/shopping_content.twig" %}
</div>
{% endblock %}
