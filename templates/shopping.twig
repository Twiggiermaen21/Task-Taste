{% extends "layout.twig" %}
{% block main_title %}{{ __('your_market') }}{% endblock %}
{% block main_subtitle %}{{ __('your_market_desc') }}{% endblock %}
{% block content %}


<form hx-post="/grocy/shopping/store" hx-target="#stores-list" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-2 pr-2 shadow-sm border border-gray-100/50 dark:border-white/5 flex items-center relative overflow-hidden">
        <div class="flex items-center w-full relative z-10">
            <input type="text" name="name" placeholder="{{ __('new_store_placeholder') }}" required class="flex-1 bg-transparent border-none outline-none font-bold text-app-black dark:text-white placeholder-gray-400 py-3 px-4 text-[15px]">
            <button type="submit" class="bg-app-black dark:bg-app-accent text-white dark:text-app-black w-12 h-12 rounded-full flex items-center justify-center shrink-0 hover:-translate-y-0.5 active:scale-95 transition-transform shadow-[0_4px_14px_rgba(0,0,0,0.15)] relative z-20">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
            </button>
        </div>
    </div>
</form>

<div id="stores-list">
    {% include "partials/shopping_content.twig" %}
</div>
{% endblock %}
