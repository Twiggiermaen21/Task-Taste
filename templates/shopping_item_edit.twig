{% extends "layout.twig" %}
{% block header_title %}Edytuj Produkt{% endblock %}
{% block content %}
<div class="mb-8 mt-2">
    <div class="inline-block bg-app-lime px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">Korekta</div>
    <h2 class="text-[36px] font-black text-app-black tracking-tighter leading-none">Modyfikuj Przedmiot</h2>
</div>

<form action="/grocy/shopping/item/{{ item.id }}/edit" method="post" enctype="multipart/form-data" class="bg-white rounded-[32px] p-6 shadow-sm border border-gray-100/50 space-y-6">
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Nazwa Produktu</label>
        <input type="text" name="name" value="{{ item.name }}" required class="w-full bg-gray-50 rounded-2xl border-none outline-none font-bold text-app-black px-4 py-3 text-[16px] focus:ring-2 focus:ring-app-black transition-all shadow-inner">
    </div>
    
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Zdjęcie Produktu</label>
        {% if item.image %}
            <div class="w-full h-32 rounded-2xl bg-gray-100 mb-3 bg-cover bg-center" style="background-image: url('/grocy/uploads/{{ item.image }}')"></div>
        {% endif %}
        <input type="file" name="image" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-black file:bg-gray-100 file:text-app-black hover:file:bg-gray-200 cursor-pointer">
    </div>
    
    <div class="pt-4">
        <button type="submit" class="w-full bg-app-lime text-black py-4 rounded-full font-black uppercase tracking-widest text-[13px] hover:-translate-y-1 active:scale-95 transition-transform shadow-lg">
            Zatwierdź Zmiany
        </button>
    </div>
</form>
{% endblock %}
