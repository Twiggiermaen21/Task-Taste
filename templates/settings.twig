{% extends "layout.twig" %}
{% block main_title %}{{ __('preferences_title') }}{% endblock %}
{% block main_subtitle %}{{ __('my_account_title') }}{% endblock %}
{% block content %}


<div class="space-y-6 pb-24">
    <form action="/settings/update" method="post" class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-6 shadow-sm border border-gray-100/50 dark:border-white/5 space-y-6">
        <!-- Theme Color -->
        <div>
            <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">{{ __('theme_color_label') }}</label>
            <div class="flex flex-wrap gap-3">
                {% set colors = ['#D4F67B', '#E2D5FC', '#FFF4CA', '#FFDBDE', '#D9E8FE', '#0F0F0F'] %}
                {% for color in colors %}
                    <label class="relative cursor-pointer group js-color-option">
                        <input type="radio" name="theme_color" value="{{ color }}" class="sr-only" {% if user_pref.theme_color == color %}checked{% endif %} onchange="updateSettingsUI()">
                        <div class="js-color-preview w-12 h-12 rounded-full border-4 transition-all group-hover:scale-110 shadow-sm {% if user_pref.theme_color == color %}border-app-black dark:border-white ring-4 ring-app-accent/30{% else %}border-white dark:border-gray-800{% endif %}" style="background-color: {{ color }};">
                            <div class="js-check-icon absolute inset-0 flex items-center justify-center {% if user_pref.theme_color != color %}hidden{% endif %}">
                                <svg class="w-6 h-6 {% if color == '#0F0F0F' %}text-white{% else %}text-app-black{% endif %}" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                        </div>
                    </label>
                {% endfor %}
            </div>
        </div>

        <!-- Language -->
        <div>
            <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">{{ __('app_lang') }}</label>
            <select name="language" class="w-full bg-gray-50 dark:bg-gray-800 rounded-2xl border-none outline-none font-bold text-app-black dark:text-white px-4 py-3 text-[15px] focus:ring-2 focus:ring-black dark:focus:ring-app-accent appearance-none cursor-pointer">
                <option value="pl" {% if user_pref.language == 'pl' %}selected{% endif %}>🇵🇱 Polski</option>
                <option value="en" {% if user_pref.language == 'en' %}selected{% endif %}>🇺🇸 English</option>
            </select>
        </div>

    <!-- Theme Mode -->
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-3">{{ __('appearance_mode') }}</label>
        <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer group js-mode-option">
                <input type="radio" name="theme_mode" value="light" class="sr-only" {% if user_pref.theme_mode == 'light' %}checked{% endif %} onchange="updateSettingsUI()">
                <div class="js-mode-preview bg-gray-50 dark:bg-gray-800 rounded-2xl py-4 px-4 flex flex-col items-center justify-center gap-2 border-4 transition-all {% if user_pref.theme_mode == 'light' %}border-app-accent bg-app-accent/10 shadow-md scale-[1.02]{% else %}border-transparent opacity-60 grayscale-[0.5]{% endif %}">
                    <span class="text-2xl">☀️</span>
                    <span class="font-black text-xs uppercase tracking-widest text-app-black dark:text-white">{{ __('light_mode') }}</span>
                    <div class="js-check-icon absolute top-2 right-2 w-5 h-5 bg-app-accent rounded-full flex items-center justify-center {% if user_pref.theme_mode != 'light' %}hidden{% endif %}">
                        <svg class="w-3 h-3 text-app-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                </div>
            </label>
            <label class="relative cursor-pointer group js-mode-option">
                <input type="radio" name="theme_mode" value="dark" class="sr-only" {% if user_pref.theme_mode == 'dark' %}checked{% endif %} onchange="updateSettingsUI()">
                <div class="js-mode-preview bg-gray-50 dark:bg-gray-800 rounded-2xl py-4 px-4 flex flex-col items-center justify-center gap-2 border-4 transition-all {% if user_pref.theme_mode == 'dark' %}border-app-accent bg-app-accent/10 shadow-md scale-[1.02]{% else %}border-transparent opacity-60 grayscale-[0.5]{% endif %}">
                    <span class="text-2xl">🌙</span>
                    <span class="font-black text-xs uppercase tracking-widest text-app-black dark:text-white">{{ __('dark_mode') }}</span>
                    <div class="js-check-icon absolute top-2 right-2 w-5 h-5 bg-app-accent rounded-full flex items-center justify-center {% if user_pref.theme_mode != 'dark' %}hidden{% endif %}">
                        <svg class="w-3 h-3 text-app-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                </div>
            </label>
        </div>
    </div>

    <!-- Avatar Icon -->
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-3">{{ __('profile_icon') }}</label>
        
        <div class="mb-4">
            <span class="block text-[12px] text-gray-500 dark:text-gray-400 mb-2">{{ __('choose_emoji') }}</span>
            <div class="flex flex-wrap gap-2">
                {% set icons = ['👤', '🥘', '🛒', '⚡', '🌟', '🥕', '🍕', '🍰'] %}
                {% for icon in icons %}
                    <label class="relative cursor-pointer group js-avatar-option">
                        <input type="radio" name="avatar" value="{{ icon }}" class="sr-only" {% if user_pref.avatar == icon %}checked{% endif %} onchange="updateSettingsUI()">
                        <div class="js-avatar-preview w-12 h-12 rounded-2xl bg-gray-50 dark:bg-gray-800 flex items-center justify-center text-2xl border-4 transition-all hover:bg-gray-100 dark:hover:bg-gray-700 {% if user_pref.avatar == icon %}border-app-accent bg-app-accent/10 shadow-md scale-110{% else %}border-transparent opacity-60{% endif %}">
                            {{ icon }}
                        </div>
                        <div class="js-check-icon absolute -top-1 -right-1 w-4 h-4 bg-app-accent rounded-full flex items-center justify-center shadow-sm {% if user_pref.avatar != icon %}hidden{% endif %}">
                            <svg class="w-2.5 h-2.5 text-app-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                    </label>
                {% endfor %}
            </div>
        </div>

    </div>

        <button type="submit" class="w-full bg-app-black text-white py-4 rounded-full font-black uppercase tracking-widest text-[13px] hover:-translate-y-1 active:scale-95 transition-transform shadow-lg">
            {{ __('save_changes') }}
        </button>
    </form>

    <!-- Logout Section -->
    <div class="pt-4">
        <div class="bg-red-50 dark:bg-red-900/10 rounded-[32px] p-6 border border-red-100 dark:border-red-900/20">
            <h3 class="text-red-600 dark:text-red-400 font-black text-sm uppercase tracking-widest mb-4">{{ __('security_zone') }}</h3>
            <p class="text-red-400 dark:text-red-500 text-[13px] font-medium mb-4">{{ __('logout_desc') }}</p>
            <a href="/logout" class="block w-full text-center bg-white dark:bg-red-900/20 text-red-600 dark:text-red-400 py-3.5 rounded-full font-bold border border-red-100 dark:border-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors shadow-sm">
                {{ __('logout') }}
            </a>
        </div>
    </div>
</div>
<script>
function updateSettingsUI() {
    // 1. Update Color Options
    document.querySelectorAll('.js-color-option').forEach(option => {
        const input = option.querySelector('input');
        const preview = option.querySelector('.js-color-preview');
        const check = option.querySelector('.js-check-icon');
        
        if (input.checked) {
            preview.classList.remove('border-white', 'dark:border-gray-800');
            preview.classList.add('border-app-black', 'dark:border-white', 'ring-4', 'ring-app-accent/30');
            check.classList.remove('hidden');
        } else {
            preview.classList.add('border-white', 'dark:border-gray-800');
            preview.classList.remove('border-app-black', 'dark:border-white', 'ring-4', 'ring-app-accent/30');
            check.classList.add('hidden');
        }
    });

    // 2. Update Mode Options
    document.querySelectorAll('.js-mode-option').forEach(option => {
        const input = option.querySelector('input');
        const preview = option.querySelector('.js-mode-preview');
        const check = option.querySelector('.js-check-icon');
        
        if (input.checked) {
            preview.classList.remove('border-transparent', 'opacity-60', 'grayscale-[0.5]');
            preview.classList.add('border-app-accent', 'bg-app-accent/10', 'shadow-md', 'scale-[1.02]');
            check.classList.remove('hidden');
        } else {
            preview.classList.add('border-transparent', 'opacity-60', 'grayscale-[0.5]');
            preview.classList.remove('border-app-accent', 'bg-app-accent/10', 'shadow-md', 'scale-[1.02]');
            check.classList.add('hidden');
        }
    });

    // 3. Update Avatar Options
    document.querySelectorAll('.js-avatar-option').forEach(option => {
        const input = option.querySelector('input');
        const preview = option.querySelector('.js-avatar-preview');
        const check = option.querySelector('.js-check-icon');
        
        if (input.checked) {
            preview.classList.remove('border-transparent', 'opacity-60');
            preview.classList.add('border-app-accent', 'bg-app-accent/10', 'shadow-md', 'scale-110');
            check.classList.remove('hidden');
        } else {
            preview.classList.add('border-transparent', 'opacity-60');
            preview.classList.remove('border-app-accent', 'bg-app-accent/10', 'shadow-md', 'scale-110');
            check.classList.add('hidden');
        }
    });
}
</script>
{% endblock %}
