{% extends "layout.twig" %}
{% block header_title %}{{ group.name|slice(0, 15) }}{% if group.name|length > 15 %}...{% endif %}{% endblock %}
{% block content %}
<div class="mb-8 flex justify-between items-start">
    <div>
        <div class="inline-block bg-[#E2D5FC] px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">Kategoria Zadań</div>
        <h2 class="text-[40px] font-black text-app-black tracking-tighter leading-none">{{ group.name }}</h2>
    </div>
    <div class="mt-2">
        <button hx-delete="/tasks/group/{{ group.id }}" hx-confirm="Trwale usunąć grupę wraz z zadaniami?" class="bg-red-50 text-red-600 w-10 h-10 rounded-full flex items-center justify-center hover:bg-red-100 transition-colors" title="Usuń grupę">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
    </div>
</div>

<form hx-post="/tasks/{{ group.id }}/task" hx-encoding="multipart/form-data" hx-target="#tasks-list" class="mb-8" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="bg-white rounded-[28px] p-5 shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-gray-100/50 mb-3 space-y-4">
        <input type="text" name="title" placeholder="Nowe zadanie..." required class="w-full bg-transparent border-none outline-none font-bold text-app-black placeholder-gray-400 text-[18px]">
        
        <div class="h-px bg-gray-100"></div>
        
        <input type="text" name="description" placeholder="Krótki opis (opcjonalnie)" class="w-full bg-transparent border-none outline-none font-medium text-gray-500 placeholder-gray-400 text-[14px]">
        
        <div class="flex gap-2 pt-2 items-center">
            <input type="date" name="due_date" class="bg-gray-50 text-app-black rounded-xl px-4 py-3 text-[14px] font-bold border border-gray-100 outline-none w-full shadow-inner">
            <input type="color" name="color" value="#E2D5FC" class="w-12 h-12 rounded-xl cursor-pointer border-0 shadow-inner overflow-hidden p-0 bg-transparent shrink-0">
        </div>
        
        <div class="h-px bg-gray-100"></div>
        
        <div>
            <input type="file" name="image" accept="image/*" class="text-[11px] text-gray-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-[11px] file:font-bold file:bg-gray-50 file:text-app-black hover:file:bg-gray-100 transition-colors w-full cursor-pointer outline-none">
        </div>
    </div>
    <button type="submit" class="w-full bg-app-black text-white py-4 rounded-full font-bold uppercase tracking-widest text-[13px] flex items-center justify-center gap-2 hover:-translate-y-1 active:scale-95 transition-transform shadow-[0_8px_20px_rgba(0,0,0,0.15)]">
        UTWÓRZ ZADANIE <span class="tracking-tighter font-black text-[#E2D5FC]">>></span>
    </button>
</form>

<div class="flex items-center justify-between mb-4 mt-2">
    <h3 class="text-[18px] font-black tracking-tight">Oczekujące</h3>
</div>

<div id="tasks-list">
    {% include "partials/tasks_items.twig" %}
</div>

<!-- Task Detail Modal -->
<div id="task-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-app-black/60 backdrop-blur-sm" onclick="closeTaskModal()"></div>
    <div class="absolute bottom-0 left-0 right-0 max-w-md mx-auto h-[70vh] bg-white dark:bg-[#1A1D1F] rounded-t-[40px] shadow-2xl p-8 overflow-y-auto translate-y-full transition-transform duration-300 ease-out" id="task-modal-container">
        <div class="flex justify-center mb-6">
            <div class="w-12 h-1.5 bg-gray-100 dark:bg-white/10 rounded-full"></div>
        </div>
        
        <div id="task-modal-image" class="w-full h-48 rounded-[32px] bg-gray-100 dark:bg-gray-800 mb-6 bg-cover bg-center shadow-inner hidden"></div>
        
        <div class="flex items-center gap-3 mb-2">
            <span id="task-modal-color" class="w-3 h-3 rounded-full"></span>
            <span id="task-modal-group" class="text-[11px] font-black uppercase tracking-widest text-gray-400"></span>
        </div>
        
        <h2 id="task-modal-title" class="text-[32px] font-black text-app-black dark:text-white tracking-tighter leading-tight mb-4"></h2>
        
        <div class="space-y-6">
            <div>
                <h4 class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Termin</h4>
                <div id="task-modal-date" class="text-[16px] font-bold text-app-black dark:text-white"></div>
            </div>
            
            <div id="task-modal-desc-container">
                <h4 class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Opis</h4>
                <p id="task-modal-desc" class="text-[15px] font-medium text-gray-500 dark:text-gray-400 leading-relaxed"></p>
            </div>
        </div>
    </div>
</div>

<script>
function openTaskModal(title, group, date, color, image, desc) {
    document.getElementById('task-modal-title').innerText = title;
    document.getElementById('task-modal-group').innerText = group;
    document.getElementById('task-modal-date').innerText = date || 'Brak terminu';
    document.getElementById('task-modal-color').style.backgroundColor = color || '#CBD5E0';
    
    const imageEl = document.getElementById('task-modal-image');
    if (image && image !== 'null' && image !== '') {
        imageEl.style.backgroundImage = `url('/uploads/${image}')`;
        imageEl.classList.remove('hidden');
    } else {
        imageEl.classList.add('hidden');
    }
    
    const descEl = document.getElementById('task-modal-desc');
    const descContainer = document.getElementById('task-modal-desc-container');
    if (desc && desc !== 'null' && desc !== '') {
        descEl.innerText = desc;
        descContainer.classList.remove('hidden');
    } else {
        descContainer.classList.add('hidden');
    }

    const modal = document.getElementById('task-modal');
    const container = document.getElementById('task-modal-container');
    const header = document.getElementById('main-header');
    
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (header) header.classList.add('opacity-0', 'pointer-events-none');
    
    setTimeout(() => {
        container.classList.remove('translate-y-full');
    }, 10);
}

function closeTaskModal() {
    const modal = document.getElementById('task-modal');
    const container = document.getElementById('task-modal-container');
    const header = document.getElementById('main-header');
    
    container.classList.add('translate-y-full');
    document.body.style.overflow = '';
    if (header) header.classList.remove('opacity-0', 'pointer-events-none');
    
    setTimeout(() => {
        modal.classList.add('hidden');
    }, 300);
}
</script>
{% endblock %}
