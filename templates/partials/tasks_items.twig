<div class="flex flex-col gap-4 pb-24">
    {% for group, items in grouped_tasks %}
        <div class="mb-4">
            <h3 class="text-[18px] font-black tracking-tight text-app-black dark:text-white uppercase mb-3 ml-2">{{ group }}</h3>
            
            <div class="flex flex-col gap-3">
                {% for task in items %}
                    <div class="bg-white dark:bg-[#1A1D1F] rounded-[28px] p-4 flex items-center gap-4 shadow-sm border-2 transition-all {% if task.is_completed %}border-app-accent bg-app-accent/5 opacity-90{% else %}border-gray-100/50 dark:border-white/5 hover:-translate-y-0.5 hover:shadow-md active:scale-[0.98]{% endif %} group pointer-events-auto relative overflow-hidden">
                        
                        <label class="shrink-0 flex items-center p-2 cursor-pointer z-20">
                            <input type="checkbox" {% if task.is_completed %}checked{% endif %} class="custom-checkbox" hx-patch="/tasks/item/{{ task.id }}/toggle" hx-target="#tasks-list">
                        </label>
                        
                        {% if task.image %}
                        <div class="w-12 h-12 rounded-[14px] bg-gray-100 dark:bg-gray-800 shrink-0 bg-cover bg-center border border-gray-100 dark:border-white/5" style="background-image: url('/uploads/{{ task.image }}')"></div>
                        {% endif %}
                        
                        <div class="flex-1 min-w-0 cursor-pointer z-10" onclick="openTaskModal('{{ task.title|e('js') }}', '{{ group|e('js') }}', '{{ task.due_date }}', '{{ task.color }}', '{{ task.image }}', '{{ task.description|e('js') }}')">
                            <strong class="block text-[16px] font-bold truncate tracking-tight text-app-black dark:text-white leading-tight mb-0.5 {% if task.is_completed %}line-through text-gray-400 dark:text-gray-500{% endif %}">
                                {{ task.title }}
                            </strong>
                            <div class="flex items-center gap-3">
                                <span class="text-[12px] text-gray-500 dark:text-gray-400 font-semibold flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full" style="background-color: {{ task.color|default('#CBD5E0') }}"></span>
                                    {% if task.due_date %}
                                        {{ task.due_date|date('d M Y') }}
                                    {% endif %}
                                </span>
                            </div>
                        </div>

                        <div class="flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity z-20">
                            <a href="/tasks/item/{{ task.id }}/edit" class="w-9 h-9 flex items-center justify-center bg-gray-50 dark:bg-gray-800 text-app-black/50 dark:text-white/50 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors border border-gray-100 dark:border-white/5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            </a>
                            <button hx-delete="/tasks/item/{{ task.id }}" hx-target="#tasks-list" hx-confirm="{{ __('confirm_delete')|default('Usunąć to zadanie?') }}" class="w-9 h-9 flex items-center justify-center bg-red-50 dark:bg-red-900/20 text-red-500 dark:text-red-400 rounded-full hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors border border-red-100 dark:border-red-900/30">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="bg-white dark:bg-[#1A1D1F] rounded-[40px] p-12 text-center border border-gray-100/50 dark:border-white/5 shadow-sm mt-4">
            <div class="w-20 h-20 bg-gray-50 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">✅</div>
            <h3 class="text-xl font-black text-app-black dark:text-white mb-2">{{ __('no_tasks') }}</h3>
            <p class="text-gray-500 dark:text-gray-400 font-medium">{{ __('no_tasks_desc') }}</p>
        </div>
    {% endfor %}
</div>
