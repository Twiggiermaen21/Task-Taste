<div class="flex flex-col gap-3 pb-24">
    {% for task in tasks %}
        <div class="bg-white rounded-[24px] p-3 shadow-sm border border-gray-100/50 flex flex-col overflow-hidden transition-all {% if task.is_completed %}opacity-50 bg-gray-50/50{% else %}hover:-translate-y-0.5 hover:shadow-md active:scale-95{% endif %} relative group">
            
            {% if task.image %}
                <!-- Background image low opacity -->
                <div class="absolute inset-0 top-0 left-0 w-full h-1/2 bg-cover bg-center opacity-40 z-0 transition-opacity" style="background-image: url('/grocy/uploads/{{ task.image }}')">
                    <div class="absolute inset-0 bg-gradient-to-t from-white to-transparent"></div>
                </div>
            {% endif %}

            <div class="flex items-center gap-3 relative z-10 w-full">
                <!-- Toggle logic separated from body -->
                <label class="shrink-0 flex items-center p-2 pl-1 cursor-pointer">
                    <input type="checkbox" {% if task.is_completed %}checked{% endif %} class="custom-checkbox shadow-inner" hx-patch="/grocy/tasks/{{ task.id }}/toggle" hx-target="#tasks-list">
                </label>
                
                <div class="w-10 h-10 rounded-[14px] flex items-center justify-center shrink-0 transition-opacity shadow-inner {% if task.is_completed %}grayscale{% endif %}" style="background-color: {{ task.color|default('#E2D5FC') }}40;">
                    <span class="w-2.5 h-2.5 rounded-full" style="background-color: {{ task.color|default('#E2D5FC') }};"></span>
                </div>
                
                <div class="flex-1 overflow-hidden flex flex-col justify-center cursor-pointer" onclick="document.getElementById('task-modal-{{ task.id }}').classList.remove('hidden')">
                    <span class="text-[15px] font-bold text-app-black truncate w-full transition-all {% if task.is_completed %}line-through text-gray-400{% endif %}">
                        {{ task.title }}
                    </span>
                    {% if task.due_date and not task.is_completed %}
                        <span class="text-[11px] font-extrabold text-orange-600 mt-1 uppercase tracking-widest flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            {{ task.due_date|date('d.m') }}
                        </span>
                    {% elseif task.description %}
                        <span class="text-[12px] text-gray-500 font-medium truncate w-full mt-0.5">{{ task.description }}</span>
                    {% endif %}
                </div>
                
                <!-- Action Buttons: Edit and Delete -->
                <div class="flex flex-col gap-1.5 items-center shrink-0 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                     <a href="/grocy/tasks/task/{{ task.id }}/edit" class="text-app-black/50 hover:text-app-black w-7 h-7 flex items-center justify-center bg-gray-50 rounded-full transition-all border border-gray-100">
                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                     </a>
                     <button hx-delete="/grocy/tasks/task/{{ task.id }}" hx-target="#tasks-list" class="text-red-400 hover:text-red-600 w-7 h-7 flex items-center justify-center bg-red-50 rounded-full transition-all border border-red-100">
                         <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                     </button>
                </div>
            </div>
        </div>

        <!-- Task Info Modal -->
        <div id="task-modal-{{ task.id }}" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4 bg-app-black/40 backdrop-blur-sm transition-opacity">
            <div class="bg-white rounded-[40px] w-full max-w-lg overflow-hidden shadow-2xl animate-fade-in-up flex flex-col max-h-[90vh]">
                
                {% if task.image %}
                    <div class="w-full h-64 bg-cover bg-center shrink-0 border-b border-gray-100" style="background-image: url('/grocy/uploads/{{ task.image }}')"></div>
                {% endif %}

                <div class="p-8 overflow-y-auto">
                    <div class="flex items-start justify-between mb-4">
                        <div class="w-14 h-14 rounded-[20px] flex items-center justify-center shrink-0 shadow-inner" style="background-color: {{ task.color|default('#E2D5FC') }}30;">
                            <span class="w-5 h-5 rounded-full" style="background-color: {{ task.color|default('#E2D5FC') }};"></span>
                        </div>
                        
                        <button onclick="document.getElementById('task-modal-{{ task.id }}').classList.add('hidden')" class="w-10 h-10 bg-gray-100 hover:bg-gray-200 rounded-full flex items-center justify-center text-gray-500 transition-colors shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                    
                    <h2 class="text-[32px] font-black tracking-tight text-app-black leading-tight mb-3">{{ task.title }}</h2>
                    
                    {% if task.due_date %}
                        <div class="inline-flex items-center gap-2 px-4 py-2 bg-orange-50 text-orange-600 rounded-full text-[13px] font-black uppercase tracking-widest mb-4">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            {{ task.due_date }}
                        </div>
                    {% endif %}

                    {% if task.description %}
                        <div class="text-[16px] text-gray-500 font-medium leading-relaxed mt-2 p-4 bg-gray-50 rounded-[24px]">
                            {{ task.description|nl2br }}
                        </div>
                    {% endif %}
                    
                    <div class="mt-8 pt-6 border-t border-gray-100 flex gap-3">
                         <a href="/grocy/tasks/task/{{ task.id }}/edit" class="flex-1 bg-[#E2D5FC] text-black py-4 rounded-full font-black uppercase tracking-widest text-[13px] text-center hover:scale-[1.02] active:scale-95 transition-all shadow-sm">
                             Edytuj Opcje
                         </a>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="bg-transparent rounded-3xl p-6 text-center border-2 border-dashed border-gray-200 mt-2 hover:bg-white transition-colors">
            <p class="text-app-black font-extrabold text-[15px] mb-1">Czyste konto</p>
            <p class="text-[13px] text-gray-500 font-medium">Brak zadań w tej grupie.</p>
        </div>
    {% endfor %}
</div>
