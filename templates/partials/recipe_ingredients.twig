<div class="flex flex-col gap-2.5 pb-24">
    {% for ingredient in ingredients %}
        <div class="bg-white rounded-2xl p-4 flex items-center justify-between shadow-sm border border-gray-100/50 group hover:shadow-md transition-shadow">
            <div class="flex items-center gap-4">
                <div class="w-2.5 h-2.5 rounded-full bg-app-yellow shrink-0"></div>
                <span class="text-[15px] font-bold text-app-black">{{ ingredient.name }}</span>
            </div>
            <button hx-delete="/grocy/recipes/ingredient/{{ ingredient.id }}" hx-target="#ingredients-list" hx-confirm="Usunąć ten składnik?" class="shrink-0 w-8 h-8 flex items-center justify-center bg-red-50 text-red-400 rounded-full hover:bg-red-100 transition-colors opacity-0 group-hover:opacity-100 border border-red-50">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
        </div>
    {% else %}
        <div class="bg-transparent rounded-3xl p-6 text-center border-2 border-dashed border-gray-200 mt-2">
            <p class="text-app-black font-extrabold text-[15px] mb-1">Brak składników</p>
            <p class="text-[13px] text-gray-500 font-medium">Dodaj produkty by ugotować danie.</p>
        </div>
    {% endfor %}
</div>
