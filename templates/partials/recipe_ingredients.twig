<div class="flex flex-col gap-2.5 pb-24">
    {% for ingredient in ingredients %}
        <div class="bg-white rounded-2xl p-4 flex items-center gap-4 shadow-sm border border-gray-100/50 hover:shadow-md transition-shadow">
            <div class="w-2.5 h-2.5 rounded-full bg-app-yellow shrink-0"></div>
            <span class="text-[15px] font-bold text-app-black">{{ ingredient.name }}</span>
        </div>
    {% else %}
        <div class="bg-transparent rounded-3xl p-6 text-center border-2 border-dashed border-gray-200 mt-2">
            <p class="text-app-black font-extrabold text-[15px] mb-1">Brak składników</p>
            <p class="text-[13px] text-gray-500 font-medium">Dodaj produkty by ugotować danie.</p>
        </div>
    {% endfor %}
</div>
