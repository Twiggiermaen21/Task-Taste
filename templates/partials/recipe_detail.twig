{% if recipe.image %}
<div class="w-full h-64 rounded-[40px] bg-gray-100 mb-6 bg-cover bg-center shadow-inner relative overflow-hidden" style="background-image: url('/uploads/{{ recipe.image }}')">
    <div class="absolute inset-0 bg-gradient-to-t from-app-black/90 via-app-black/20 to-transparent flex items-end p-6">
        <h2 class="text-white text-[32px] font-black tracking-tighter leading-tight relative z-10">{{ recipe.title }}</h2>
    </div>
</div>
{% endif %}

<div class="mb-8 flex justify-between items-start">
    <div>
        <div class="inline-block bg-app-yellow px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">Przepis</div>
        {% if not recipe.image %}
            <h2 class="text-[36px] font-black text-app-black dark:text-white tracking-tighter leading-none">{{ recipe.title }}</h2>
        {% endif %}
    </div>

    <div class="flex items-center gap-2 mt-2">
        <a href="/recipes/{{ recipe.id }}/edit" class="bg-gray-100 dark:bg-gray-800 text-app-black dark:text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" title="Edytuj">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
        </a>
    </div>
</div>

{% if recipe.instructions %}
<div class="bg-app-black dark:bg-[#2D3135] text-white rounded-[32px] p-7 mb-8 shadow-xl relative overflow-hidden">
    <div class="absolute -bottom-10 -right-10 w-40 h-40 border-[8px] border-white/5 rounded-full"></div>
    <h3 class="text-xs font-bold opacity-50 mb-3 uppercase tracking-widest flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Jak przyrządzić
    </h3>
    <p class="text-[15px] max-w-sm leading-relaxed relative z-10 font-medium text-white/90">{{ recipe.instructions|nl2br }}</p>
</div>
{% endif %}

<div class="flex items-center justify-between mb-5">
    <h3 class="text-[18px] font-black tracking-tight dark:text-white">Składniki</h3>
</div>

<div id="ingredients-list">
    {% include "partials/recipe_ingredients.twig" %}
</div>

<!-- Ingredients Form (Only for modal or view) -->
<form hx-post="/recipes/{{ recipe.id }}/ingredient" hx-target="#ingredients-list" class="mt-6" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="relative flex items-center bg-white dark:bg-gray-800 rounded-full p-2 pr-2 shadow-sm border border-gray-100/50 dark:border-white/5">
        <input type="text" name="name" placeholder="Dodaj składnik..." required class="flex-1 bg-transparent border-none outline-none font-bold text-app-black dark:text-white placeholder-gray-400 py-3 px-4 text-[14px]">
        <button type="submit" class="bg-app-black dark:bg-app-accent text-white dark:text-app-black px-6 py-3.5 rounded-full font-bold uppercase tracking-widest text-[10px] shrink-0 active:scale-95 transition-transform">
            Dodaj
        </button>
    </div>
</form>
