<div class="flex flex-col gap-8 pb-24">
    {% for category, items in grouped_recipes %}
        <div class="mb-10">
            <div class="flex items-center gap-3 mb-4 ml-2">
                <span class="text-2xl">{{ category_emojis[category]|default('🍴') }}</span>
                <h3 class="text-[19px] font-black tracking-tight text-app-black dark:text-white uppercase">{{ category }}</h3>
            </div>
            
            <div class="grid grid-cols-1 gap-4">
                {% for recipe in items %}
                    <div class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-4 flex gap-4 shadow-sm border border-gray-100/50 dark:border-white/5 hover-lift active-scale transition-all group relative overflow-hidden cursor-pointer"
                         hx-get="/recipes/{{ recipe.id }}" 
                         hx-target="#recipe-modal-body">
                        <div class="w-24 h-24 rounded-[24px] bg-gray-50 dark:bg-gray-800 shrink-0 flex items-center justify-center text-3xl">
                            🍳
                        </div>
                        
                        <div class="flex-1 flex flex-col justify-center min-w-0">
                            <h4 class="text-[17px] font-extrabold text-app-black dark:text-white truncate leading-tight mb-1">{{ recipe.title }}</h4>
                            <p class="text-[13px] text-gray-500 dark:text-gray-400 font-medium line-clamp-2 leading-snug">{{ recipe.instructions }}</p>
                        </div>

                    </div>
                {% endfor %}
            </div>
        </div>
    {% else %}
        <div class="bg-white dark:bg-[#1A1D1F] rounded-[40px] p-12 text-center border border-gray-100/50 dark:border-white/5 shadow-sm mt-4">
            <div class="w-20 h-20 bg-gray-50 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">📖</div>
            <h3 class="text-xl font-black text-app-black dark:text-white mb-2">{{ __('no_recipes') }}</h3>
            <p class="text-gray-500 dark:text-gray-400 font-medium">{{ __('no_recipes_desc') }}</p>
        </div>
    {% endfor %}
</div>
