<div class="flex flex-col divide-y divide-slate-100">
    {% for user in users %}
        <div class="p-6 hover:bg-slate-50/50 transition-colors flex flex-col gap-4">
            <!-- User Identity -->
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-slate-100 dark:bg-white/10 flex items-center justify-center text-xl shrink-0 font-bold text-slate-500">
                    {{ user.avatar|default(user.username|first|upper) }}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-bold text-slate-800 dark:text-white text-lg leading-tight">{{ user.username }}</div>
                    <div class="text-sm text-slate-500 truncate">{{ user.email|default('Brak e-maila') }}</div>
                </div>
            </div>

            <!-- Role & Status Tags -->
            <div class="flex flex-wrap gap-2">
                {% if user.is_admin %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider bg-purple-100 text-purple-800 border border-purple-200">
                        Administrator
                    </span>
                {% else %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider bg-slate-100 text-slate-600 border border-slate-200">
                        Użytkownik
                    </span>
                {% endif %}

                {% if user.is_active == 1 %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider bg-green-100 text-green-800 border border-green-200">
                        Aktywny
                    </span>
                {% else %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider bg-red-100 text-red-800 border border-red-200">
                        Zablokowany
                    </span>
                {% endif %}
            </div>

            <!-- Actions Section -->
            <div class="pt-2 flex items-center justify-between border-t border-slate-50 mt-1">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">ID: #{{ user.id }}</span>
                
                <div class="flex gap-2">
                    {% if user.id != session.user_id %}
                        {% if user.is_active == 1 %}
                            <button hx-patch="/grocy/admin/user/{{ user.id }}/toggle-status"
                                    hx-target="#users-list"
                                    class="text-orange-600 hover:bg-orange-50 bg-white dark:bg-[#1A1D1F] px-4 py-2 rounded-xl transition-all font-bold text-[11px] uppercase tracking-wider border border-orange-100 shadow-sm active:scale-95">
                                Zablokuj
                            </button>
                        {% else %}
                            <button hx-patch="/grocy/admin/user/{{ user.id }}/toggle-status"
                                    hx-target="#users-list"
                                    class="text-green-600 hover:bg-green-50 bg-white dark:bg-[#1A1D1F] px-4 py-2 rounded-xl transition-all font-bold text-[11px] uppercase tracking-wider border border-green-100 shadow-sm active:scale-95">
                                Odblokuj
                            </button>
                        {% endif %}
                        <button hx-delete="/grocy/admin/user/{{ user.id }}"
                                hx-confirm="Czy na pewno chcesz usunąć użytkownika '{{ user.username }}'? Wszystkie jego dane zostaną trwale usunięte."
                                hx-target="#users-list"
                                class="text-red-500 hover:bg-red-50 bg-white dark:bg-[#1A1D1F] px-4 py-2 rounded-xl transition-all font-bold text-[11px] uppercase tracking-wider border border-red-100 shadow-sm active:scale-95">
                            Usuń
                        </button>
                    {% else %}
                        <div class="px-4 py-2 bg-slate-50 rounded-xl">
                            <span class="text-slate-400 text-[10px] uppercase tracking-wider font-bold">Twoje konto</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="p-12 text-center text-slate-500">
            <div class="text-4xl mb-4">👥</div>
            <p class="font-bold">Brak zarejestrowanych użytkowników</p>
        </div>
    {% endfor %}
</div>

