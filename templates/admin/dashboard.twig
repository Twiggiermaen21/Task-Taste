{% extends "layout.twig" %}
{% block content %}
<div class="flex justify-between items-center mb-6 mt-2">
    <h2 class="text-2xl font-normal text-slate-800">Panel Administratora</h2>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-6">
    <div class="p-6 border-b border-slate-100">
        <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">Zarządzanie użytkownikami</h3>
        <p class="text-sm text-slate-500 mt-1">Usuwanie kont usunie również wszystkie przypisane do nich dane (Sklepy, Przepisy, Zadania).</p>
    </div>
    
    <div class="overflow-x-auto" id="users-list">
        {% include "admin/partials/users_list.twig" %}
    </div>
</div>
{% endblock %}
