{% extends "layout.twig" %}
{% block content %}
<div class="flex flex-col items-center justify-center min-h-[70vh]">
    <div class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-8 w-full max-w-sm shadow-sm border border-slate-100 dark:border-white/5">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-black text-slate-800 dark:text-white tracking-tight">{{ __('welcome') }}</h1>
            <p class="text-slate-500 dark:text-gray-400 text-sm mt-1">{{ __('sign_in_desc')|default('Zaloguj się do swojego konta') }}</p>
        </div>

        {% if error %}
            <div class="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 p-3 rounded-xl text-sm mb-6 text-center border border-red-100 dark:border-red-900/30">{{ error }}</div>
        {% endif %}

        <form action="/login" method="post" class="flex flex-col gap-6">
            <div>
                <label class="block text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2">{{ __('email') }}</label>
                <input type="email" name="email" required class="material-input text-base" placeholder="twój@email.com">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2">{{ __('password') }}</label>
                <input type="password" name="password" required class="material-input text-base">
            </div>
            
            <button type="submit" class="mt-4 main-btn">
                {{ __('sign_in') }}
            </button>
        </form>

        <p class="mt-8 text-center text-sm text-slate-500 dark:text-gray-400">
            {{ __('no_account') }} <a href="/register" class="text-app-accent font-bold hover:underline" style="color: var(--app-accent)">{{ __('sign_up') }}</a>
        </p>
    </div>
</div>
{% endblock %}
