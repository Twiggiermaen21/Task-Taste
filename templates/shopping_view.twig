{% extends "layout.twig" %}
{% block header_title %}{{ store.name|slice(0, 15) }}{% if store.name|length > 15 %}...{% endif %}{% endblock %}
{% block content %}

{% if store.image %}
<div class="w-full h-48 rounded-[36px] bg-gray-100 mb-6 bg-cover bg-center shadow-inner relative overflow-hidden" style="background-image: url('/grocy/uploads/{{ store.image }}')">
    <div class="absolute inset-0 bg-gradient-to-t from-app-black/60 to-transparent flex items-end p-6">
        <h2 class="text-white text-[32px] font-black tracking-tighter leading-none relative z-10">{{ store.name }}</h2>
    </div>
</div>
{% endif %}

<div class="mb-8 flex justify-between items-start">
    <div>
        <div class="inline-block bg-app-lime px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">Lista Zakupów</div>
        
        {% if not store.image %}
            <h2 class="text-[40px] font-black text-app-black tracking-tighter leading-none">{{ store.name }}</h2>
        {% endif %}
    </div>
    
    <div class="flex items-center gap-2 mt-2">
        <a href="/grocy/shopping/{{ store.id }}/edit" class="bg-gray-100 text-app-black w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-200 transition-colors" title="Edytuj">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
        </a>
        <button hx-delete="/grocy/shopping/store/{{ store.id }}" hx-confirm="Trwale usunąć tę listę ze zdjęciem?" class="bg-red-50 text-red-600 w-10 h-10 rounded-full flex items-center justify-center hover:bg-red-100 transition-colors" title="Usuń">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
    </div>
</div>

<form hx-post="/grocy/shopping/{{ store.id }}/item" hx-target="#shopping-items" class="mb-10" onsubmit="setTimeout(()=>this.reset(), 10)">
    <div class="relative flex items-center bg-white rounded-full p-2 pr-2 shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-gray-100/50">
        <input type="text" name="name" placeholder="Co kupujesz?" required class="flex-1 bg-transparent border-none outline-none font-bold text-app-black placeholder-gray-400 py-4 px-5 text-[16px]">
        <button type="submit" class="bg-app-black text-white px-7 py-4 rounded-full font-bold uppercase tracking-widest text-[12px] flex items-center gap-2 shrink-0 hover:-translate-y-0.5 active:scale-95 transition-transform shadow-[0_4px_14px_rgba(0,0,0,0.15)]">
            DODAJ <span class="tracking-tighter font-black">>></span>
        </button>
    </div>
</form>

<div id="shopping-items">
    {% include "partials/shopping_items.twig" %}
</div>
{% endblock %}
