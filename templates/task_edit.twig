{% extends "layout.twig" %}
{% block header_title %}Edytuj: {{ task.title|slice(0, 15) }}{% endblock %}
{% block content %}
<div class="mb-8 mt-2">
    <div class="inline-block bg-[#E2D5FC] px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">Edytor</div>
    <h2 class="text-[36px] font-black text-app-black tracking-tighter leading-none">Modyfikuj Zadanie</h2>
</div>

<form action="/grocy/tasks/task/{{ task.id }}/edit" method="post" enctype="multipart/form-data" class="bg-white rounded-[32px] p-6 shadow-sm border border-gray-100/50 space-y-5">
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Tytuł Zlecenia</label>
        <input type="text" name="title" value="{{ task.title }}" required class="w-full bg-gray-50 rounded-2xl border-none outline-none font-bold text-app-black px-4 py-3 text-[16px] focus:ring-2 focus:ring-app-black transition-all shadow-inner">
    </div>

    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Szczegóły / Opis</label>
        <textarea name="description" class="w-full bg-gray-50 rounded-2xl border-none outline-none font-medium text-app-black px-4 py-3 text-[14px] focus:ring-2 focus:ring-app-black transition-all shadow-inner resize-none h-24">{{ task.description }}</textarea>
    </div>
    
    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Termin</label>
            <input type="date" name="due_date" value="{{ task.due_date }}" class="bg-gray-50 text-app-black rounded-xl px-4 py-3 text-[14px] font-bold border-none shadow-inner outline-none w-full">
        </div>
        <div>
            <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Priorytet (kolor)</label>
            <input type="color" name="color" value="{{ task.color }}" class="w-full h-12 rounded-xl cursor-pointer border-0 shadow-inner overflow-hidden p-0 bg-transparent shrink-0">
        </div>
    </div>
    
    <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">Załącznik Graficzny</label>
        {% if task.image %}
            <div class="w-full h-32 rounded-2xl bg-gray-100 bg-cover bg-center mb-3 shadow-inner relative" style="background-image: url('/grocy/uploads/{{ task.image }}')"></div>
            <p class="text-[12px] text-gray-500 font-medium mb-2">Wrzuć plik, aby je podmienić.</p>
        {% else %}
            <div class="w-full h-16 rounded-2xl bg-gray-50 flex items-center justify-center border-2 border-dashed border-gray-200 mb-3">
                <span class="text-[12px] text-gray-400 font-bold">Brak pliku</span>
            </div>
        {% endif %}
        
        <input type="file" name="image" accept="image/*" class="text-[12px] text-gray-600 file:mr-4 file:py-2 file:px-6 file:rounded-[20px] file:border-0 file:text-[12px] file:font-bold file:bg-[#E2D5FC] file:text-black hover:file:bg-[#d0bcf9] transition-colors w-full cursor-pointer outline-none">
    </div>
    
    <div class="pt-4">
        <button type="submit" class="w-full bg-app-black text-white py-4 rounded-full font-black uppercase tracking-widest text-[13px] hover:-translate-y-1 active:scale-95 transition-transform shadow-[0_8px_20px_rgba(0,0,0,0.2)]">
            Aktualizuj
        </button>
    </div>
</form>
{% endblock %}
