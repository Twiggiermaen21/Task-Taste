{% extends "layout.twig" %}
{% block header_title %}{{ __('edit_task') }}{% endblock %}
{% block content %}
<div class="mb-8 mt-2">
    <div class="inline-block bg-app-purple dark:bg-app-accent px-4 py-1.5 rounded-full mb-3 text-black text-[11px] font-black uppercase tracking-widest shadow-sm">{{ __('Edytor') }}</div>
    <h2 class="text-[36px] font-black text-app-black dark:text-white tracking-tighter leading-none">{{ __('modify_task') }}</h2>
</div>

<form action="/tasks/task/{{ task.id }}/edit" method="post" class="bg-white dark:bg-[#1A1D1F] rounded-[32px] p-6 shadow-sm border border-gray-100/50 dark:border-white/5 space-y-5">
    <div>
        <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">{{ __('task_title_label') }}</label>
        <input type="text" name="title" value="{{ task.title }}" required class="w-full bg-gray-50 dark:bg-gray-800 rounded-2xl border-none outline-none font-bold text-app-black dark:text-white px-4 py-3 text-[16px] focus:ring-2 focus:ring-app-black dark:focus:ring-app-accent transition-all shadow-inner">
    </div>

    <div>
        <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">{{ __('details_label') }}</label>
        <textarea name="description" class="w-full bg-gray-50 dark:bg-gray-800 rounded-2xl border-none outline-none font-medium text-app-black dark:text-white px-4 py-3 text-[14px] focus:ring-2 focus:ring-app-black dark:focus:ring-app-accent transition-all shadow-inner resize-none h-24">{{ task.description }}</textarea>
    </div>
    
    <div class="grid grid-cols-2 gap-3">
        <div>
            <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">{{ __('due_date_label') }}</label>
            <input type="date" name="due_date" value="{{ task.due_date }}" class="bg-gray-50 dark:bg-gray-800 text-app-black dark:text-white rounded-xl px-4 py-3 text-[14px] font-bold border-none shadow-inner outline-none w-full">
        </div>
        <div>
            <label class="block text-[11px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">{{ __('priority_label') }}</label>
            <input type="color" name="color" value="{{ task.color }}" class="w-full h-12 rounded-xl cursor-pointer border-0 shadow-inner overflow-hidden p-0 bg-transparent shrink-0">
        </div>
    </div>
    
    
    <div class="pt-4">
        <button type="submit" class="w-full bg-app-black dark:bg-app-accent text-white dark:text-app-black py-4 rounded-full font-black uppercase tracking-widest text-[13px] hover:-translate-y-1 active:scale-95 transition-transform shadow-lg">
            {{ __('update_btn') }}
        </button>
    </div>
</form>
{% endblock %}
